{
  "compilerOptions": {
    "moduleResolution": "node",
    "target": "ESNext",
    "lib": ["ESNext"],
    "declaration": true,
    "outDir": "dist",
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  },
  "baseUrl": ".",
  "exclude": ["coverage", "dist", "node_modules", "test"],
  "include": ["src/**/*"]
}
