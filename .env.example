# MongoDB — same cluster as UnifiedDataServer; credentials MUST be in the URI.
# user-credits uses database DB_NAME (default user_credits), not the DB name in the URI path.
MONGODB_URI=mongodb://USER:PASSWORD@127.0.0.1:27017/?authSource=admin
DB_NAME=user_credits

# Legacy fallback only if MONGODB_URI is unset
# DB_URL=mongodb://USER:PASSWORD@127.0.0.1:27017/?authSource=admin

PORT=3100
NODE_ENV=production

# Required in production — must match UnifiedDataServer USER_CREDITS_HTTP_API_KEY
USER_CREDITS_HTTP_API_KEY=
